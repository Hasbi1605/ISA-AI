# === ISTA AI - Environment Variables ===

# Secrets only
# Internal service token (must match Laravel's AI_SERVICE_TOKEN)
AI_SERVICE_TOKEN=your_internal_api_secret

# Primary: Google AI Studio (Gemini)
GEMINI_API_KEY=your_gemini_api_key
# Required for langchain-google-genai embeddings
GOOGLE_API_KEY=your_google_api_key

# Fallback 1: GitHub Models (Primary)
GITHUB_TOKEN=your_github_token

# Fallback 2: GitHub Models (Backup) - for 2M TPM capacity
GITHUB_TOKEN_2=your_github_token_2

# Fallback 3: Groq Cloud
GROQ_API_KEY=your_groq_api_key

# LangSearch API secrets
LANGSEARCH_API_KEY=your_langsearch_api_key
LANGSEARCH_API_KEY_BACKUP=your_langsearch_api_key_backup

# Limited emergency operational overrides
LANGSEARCH_TIMEOUT=10
LANGSEARCH_RERANK_ENABLED=true
LANGSEARCH_RERANK_TIMEOUT=8

# Deprecated in .env (moved to config/chunking_summarization.yaml)
# - TOKEN_CHUNK_SIZE
# - TOKEN_CHUNK_OVERLAP
# - AGGRESSIVE_BATCH_SIZE
# - BATCH_DELAY_SECONDS
# - EMBEDDING_TIMEOUT
# - LANGSEARCH_CACHE_TTL
# - LANGSEARCH_RERANK_MODEL
# - LANGSEARCH_RERANK_MAX_DOCS
# - LANGSEARCH_RERANK_CACHE_TTL
# - LANGSEARCH_RERANK_DOC_CANDIDATES
# - LANGSEARCH_RERANK_DOC_TOP_N
# - LANGSEARCH_RERANK_WEB_CANDIDATES
# - LANGSEARCH_RERANK_WEB_TOP_N
# - LANGSEARCH_RERANK_MIN_SCORE
# - DEFAULT_SYSTEM_PROMPT
