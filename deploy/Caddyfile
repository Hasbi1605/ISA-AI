{
    email {$LETSENCRYPT_EMAIL}
}

{$APP_DOMAIN} {
    encode zstd gzip

    request_body {
        max_size 100MB
    }

    log {
        output stdout
        format console
    }

    @onlyoffice path /web-apps/* /sdkjs/* /cache/* /doc/* /coauthoring/* /spellchecker/* /healthcheck
    reverse_proxy @onlyoffice onlyoffice:80

    reverse_proxy laravel:8000 {
        flush_interval -1
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Host {host}
        # Laravel generates absolute asset/route URLs from forwarded headers.
        # Hardcode the public HTTPS port so it never emits ":0" URLs behind proxies.
        header_up X-Forwarded-Port 443
        header_up X-Forwarded-Proto {scheme}
    }
}
