# Public application
APP_NAME="ISTA AI"
APP_ENV=production
APP_KEY=base64:CHANGE_ME
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://CHANGE_ME
APP_DOMAIN=CHANGE_ME
LETSENCRYPT_EMAIL=CHANGE_ME
APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID
LOG_CHANNEL=stack
LOG_LEVEL=info
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=istanaai
DB_USERNAME=ista
DB_PASSWORD=CHANGE_ME
MYSQL_DATABASE=istanaai
MYSQL_USER=ista
MYSQL_PASSWORD=CHANGE_ME
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT

# Session, queue, cache
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis
CACHE_PREFIX=ista_
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

# Mail
MAIL_MAILER=log
MAIL_SCHEME=
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@ista-ai.app
MAIL_FROM_NAME="ISTA AI"

# OTP registration
AUTH_OTP_REGISTRATION_TTL_MINUTES=60
AUTH_OTP_REGISTRATION_MAX_ATTEMPTS=3
AUTH_OTP_REGISTRATION_DECAY_SECONDS=600
AUTH_OTP_REGISTRATION_RESEND_COOLDOWN_SECONDS=60

# Laravel -> Python internal service
AI_SERVICE_URL=http://python-ai:8001
AI_SERVICE_TOKEN=CHANGE_ME

# Python AI providers
GITHUB_TOKEN=CHANGE_ME
GITHUB_TOKEN_2=
GROQ_API_KEY=CHANGE_ME
GEMINI_API_KEY=CHANGE_ME
LANGSEARCH_API_KEY=CHANGE_ME
LANGSEARCH_API_KEY_BACKUP=

# Python AI runtime tuning
TOKEN_CHUNK_SIZE=1500
TOKEN_CHUNK_OVERLAP=150
AGGRESSIVE_BATCH_SIZE=120
BATCH_DELAY_SECONDS=0.8
EMBEDDING_TIMEOUT=30
LANGSEARCH_TIMEOUT=10
LANGSEARCH_RERANK_ENABLED=true
LANGSEARCH_RERANK_TIMEOUT=8
LANGSEARCH_RERANK_WEB_CANDIDATES=10
LANGSEARCH_RERANK_WEB_TOP_N=5
LANGSEARCH_RERANK_DOC_CANDIDATES=25
