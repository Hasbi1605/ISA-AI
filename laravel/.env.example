APP_NAME="ISTA AI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=istanaai
DB_USERNAME=root
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_KEY=

AUTH_OTP_REGISTRATION_TTL_MINUTES=60
AUTH_OTP_REGISTRATION_MAX_ATTEMPTS=3
AUTH_OTP_REGISTRATION_DECAY_SECONDS=600
AUTH_OTP_REGISTRATION_RESEND_COOLDOWN_SECONDS=60

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

AI_SERVICE_URL=http://127.0.0.1:8001
AI_DOCUMENT_SERVICE_URL=http://127.0.0.1:8002
AI_SERVICE_TOKEN=change_me_internal_api_secret
ONLYOFFICE_PUBLIC_URL=http://127.0.0.1:8080
ONLYOFFICE_INTERNAL_URL=http://onlyoffice
ONLYOFFICE_LARAVEL_INTERNAL_URL=http://laravel:8000
ONLYOFFICE_JWT_SECRET=change_me_onlyoffice_shared_secret
ONLYOFFICE_SIGNED_URL_TTL_MINUTES=30
ONLYOFFICE_CONVERSION_TIMEOUT=120
ONLYOFFICE_DOCUMENTSERVER_TAG=9.3.1.2

GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_SERVICE_ACCOUNT_PATH=
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_UPLOAD_FOLDER_NAME="ISTA AI"
GOOGLE_DRIVE_SHARED_DRIVE_ID=
GOOGLE_DRIVE_IMPERSONATED_USER_EMAIL=
GOOGLE_DRIVE_OAUTH_CLIENT_ID=
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=
GOOGLE_DRIVE_OAUTH_REDIRECT_URI=
GOOGLE_DRIVE_OAUTH_SETUP_KEY=

VITE_APP_NAME="${APP_NAME}"
